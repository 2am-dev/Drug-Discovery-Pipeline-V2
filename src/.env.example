# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for Drug Discovery Pipeline environment variables
# Place at: drug_discovery_pipeline/.env.example   (project root)
#
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your actual values.
#   3. Never commit .env to git (it is gitignored).
#
# All variables shown here use their default values from config.py.
# You only need to set variables that differ from defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Set your Ollama server address ──────────────────────────────────
OLLAMA_REMOTE_URL=http://YOUR_SERVER_IP:11434/v1
OLLAMA_LOCAL_URL=http://localhost:11434/v1

# ── REQUIRED: Set your email in User-Agent (PubMed policy) ───────────────────
HTTP_USER_AGENT=DrugDiscoveryPipeline/1.0 (research; your-email@example.com)

# ── OPTIONAL: NCBI API key (increases PubMed rate limit 3x → free) ───────────
# Apply at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── OPTIONAL: Model selection ─────────────────────────────────────────────────
LLM_MODEL=gemma4:31b-it-q8_0
EMBEDDING_MODEL=nomic-embed-text

# ── OPTIONAL: Feature flags ───────────────────────────────────────────────────
ENABLE_CHEMICAL_SYNTHESIS=false
ENABLE_DOCKING=true
ENABLE_PATENT_SEARCH=true
ENABLE_LLM_CACHE=false
ENABLE_PDF_REPORT=false

# ── OPTIONAL: Docking binary path (if not on PATH) ───────────────────────────
VINA_BINARY=vina

# ── OPTIONAL: Performance tuning ─────────────────────────────────────────────
MAX_CONTEXT_TOKENS=8000
LLM_TEMPERATURE=0.7
LLM_JSON_TEMPERATURE=0.2
PUBMED_MAX_RESULTS=150
MOL_GENERATION_COUNT=20
MOL_SHORTLIST_COUNT=5